# --- Copia este archivo a .env y rellena tus valores. NO subas .env al repo. ---

# Puerto en el que escucha el servidor
PORT=3000

# Orígenes del sitio autorizados a enviar el formulario (separados por comas)
ALLOWED_ORIGINS=https://silviaearth.com,https://www.silviaearth.com,https://javitosam.github.io

# Destinatario y remitente de los correos
MAIL_TO=info@silviaearth.com
MAIL_FROM=SilvIA Web <no-reply@silviaearth.com>

# Servidor SMTP de envío (ejemplo genérico; usa el de tu proveedor)
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-usuario-smtp
SMTP_PASS=tu-contraseña-smtp
